# Maintainer: HomeHarbor maintainers
pkgbase=homeharbor
_homeharbor_version="${HOMEHARBOR_VERSION:-0.1.0-dev}"
_homeharbor_channel="${HOMEHARBOR_CHANNEL:-dev}"
_homeharbor_source_tarball="${HOMEHARBOR_SOURCE_TARBALL:?HOMEHARBOR_SOURCE_TARBALL must point to the clean HomeHarbor source tarball}"
pkgver="${_homeharbor_version//-/_}"
pkgrel=1
arch=('x86_64')
url='https://github.com/akaishi-tech/home-harbor'
license=('GPL-3.0-only')
makedepends=('aspnet-runtime' 'dotnet-sdk' 'efitools' 'jq' 'openssl' 'pnpm' 'sbsigntools' 'systemd-ukify')
options=('!strip')

_dotnet_keys=(
  bcrypt-net-next
  microsoft-aspnetcore-authentication-jwtbearer
  microsoft-aspnetcore-openapi
  microsoft-extensions-caching-stackexchangeredis
  microsoft-entityframeworkcore
  microsoft-entityframeworkcore-abstractions
  microsoft-entityframeworkcore-relational
  microsoft-identitymodel-abstractions
  microsoft-identitymodel-jsonwebtokens
  microsoft-identitymodel-logging
  microsoft-identitymodel-protocols
  microsoft-identitymodel-protocols-openidconnect
  microsoft-identitymodel-tokens
  microsoft-openapi
  microsoft-win32-systemevents
  npgsql
  npgsql-entityframeworkcore-postgresql
  pipelines-sockets-unofficial
  qrcoder
  stackexchange-redis
  system-commandline
  system-drawing-common
  system-identitymodel-tokens-jwt
  yamldotnet
)

pkgname=(homeharbor-control homeharbor-recovery homeharbor-installer)
_dotnet_package_depends=()
for _dotnet_key in "${_dotnet_keys[@]}"; do
  pkgname+=("dotnet-${_dotnet_key}")
  _dotnet_package_depends+=("dotnet-${_dotnet_key}=${pkgver}-${pkgrel}")
done

source=("homeharbor-${_homeharbor_version}.tar.gz::file://${_homeharbor_source_tarball}")
sha256sums=('SKIP')

_source_root="homeharbor-${_homeharbor_version}"
_publish_root="publish/api"
_agent_publish_root="publish/agent"
_recovery_publish_root="publish/recovery"
_installer_publish_root="publish/installer"
_avb_helper="publish/homeharbor-avb"
_init_helper="publish/homeharbor-verity"

build() {
  local source_dir="${srcdir}/${_source_root}"
  local publish_dir="${srcdir}/${_publish_root}"
  local agent_publish_dir="${srcdir}/${_agent_publish_root}"
  local recovery_publish_dir="${srcdir}/${_recovery_publish_root}"
  local installer_publish_dir="${srcdir}/${_installer_publish_root}"
  local avb_helper="${srcdir}/${_avb_helper}"
  local init_helper="${srcdir}/${_init_helper}"

  rm -rf "${publish_dir}" "${agent_publish_dir}" "${recovery_publish_dir}" "${installer_publish_dir}" "${avb_helper}" "${init_helper}"
  mkdir -p "${publish_dir}" "${agent_publish_dir}" "${recovery_publish_dir}" "${installer_publish_dir}"

  pnpm --dir "${source_dir}" --filter homeharbor-frontend install --frozen-lockfile
  pnpm --dir "${source_dir}" --filter homeharbor-frontend build
  dotnet publish "${source_dir}/src/HomeHarbor.Api/HomeHarbor.Api.csproj" \
    -c Release \
    -o "${publish_dir}"
  dotnet publish "${source_dir}/src/HomeHarbor.Agent/HomeHarbor.Agent.csproj" \
    -c Release \
    -o "${agent_publish_dir}"
  dotnet publish "${source_dir}/src/HomeHarbor.Recovery/HomeHarbor.Recovery.csproj" \
    -c Release \
    -o "${recovery_publish_dir}"
  dotnet publish "${source_dir}/src/HomeHarbor.Installer/HomeHarbor.Installer.csproj" \
    -c Release \
    -o "${installer_publish_dir}"
  dotnet run --project "${source_dir}/src/HomeHarbor.ImageBuilder/HomeHarbor.ImageBuilder.csproj" -- \
    build-homeharbor-avb "${avb_helper}" "${source_dir}"
  dotnet run --project "${source_dir}/src/HomeHarbor.ImageBuilder/HomeHarbor.ImageBuilder.csproj" -- \
    build-homeharbor-init "${init_helper}" "${source_dir}"
}

