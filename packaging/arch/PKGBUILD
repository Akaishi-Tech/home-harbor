_dotnet_install_path() {
  local key="$1"
  _dotnet_library_info "${key}" || return
  printf '/usr/lib/dotnet/homeharbor/%s/%s/%s' "${_dotnet_id}" "${_dotnet_version}" "${_dotnet_dll}"
}

_dotnet_library_source() {
  local key="$1"
  _dotnet_library_info "${key}" || return

  local root
  for root in "${_publish_root}" "${_agent_publish_root}" "${_recovery_publish_root}" "${_installer_publish_root}"; do
    local candidate="${srcdir}/${root}/${_dotnet_dll}"
    if [[ -f "${candidate}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
  done

  echo "published HomeHarbor .NET library not found: ${_dotnet_dll}" >&2
  return 1
}

_package_dotnet_library() {
  local key="$1"
  _dotnet_library_info "${key}" || return
  local source_file
  source_file="$(_dotnet_library_source "${key}")" || return

  pkgdesc=".NET runtime library ${_dotnet_id} for HomeHarbor"
  depends=('dotnet-runtime')
  license=("${_dotnet_license}")

  install -Dm644 \
    "${source_file}" \
    "${pkgdir}/usr/lib/dotnet/homeharbor/${_dotnet_id}/${_dotnet_version}/${_dotnet_dll}"
}

_link_published_dotnet_libraries() {
  local publish_dir="$1"
  local target_dir="$2"

  for key in "${_dotnet_keys[@]}"; do
    _dotnet_library_info "${key}"
    if [[ ! -f "${publish_dir}/${_dotnet_dll}" ]]; then
      continue
    fi

    local target
    target="$(_dotnet_install_path "${key}")"
    ln -s "${target}" "${target_dir}/${_dotnet_dll}"
  done
}

package_homeharbor-control() {
  local source_dir="${srcdir}/${_source_root}"
  local publish_dir="${srcdir}/${_publish_root}"
  local agent_publish_dir="${srcdir}/${_agent_publish_root}"
  local avb_helper="${srcdir}/${_avb_helper}"
  local init_helper="${srcdir}/${_init_helper}"
  pkgdesc='HomeHarbor control plane'
  depends=(
    'aspnet-runtime'
    'android-tools'
    'btrfs-progs'
    'cryptsetup'
    'device-mapper'
    'dotnet-runtime'
    'caddy'
    'curl'
    'jq'
    'mdadm'
    'openssl'
    'podman'
    'postgresql'
    'samba'
    'smartmontools'
    'systemd'
    'tpm2-tss'
    'valkey'
    'xfsprogs'
    "${_dotnet_package_depends[@]}"
  )

  install -dm755 "${pkgdir}/usr/lib/homeharbor/api"
  install -Dm755 "${publish_dir}/HomeHarbor.Api" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.Api"
  install -Dm644 "${publish_dir}/HomeHarbor.Api.dll" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.Api.dll"
  install -Dm644 "${publish_dir}/HomeHarbor.Api.deps.json" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.Api.deps.json"
  install -Dm644 "${publish_dir}/HomeHarbor.Api.runtimeconfig.json" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.Api.runtimeconfig.json"
  install -Dm644 "${publish_dir}/HomeHarbor.Core.dll" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.Core.dll"
  install -Dm644 "${publish_dir}/HomeHarbor.Tooling.dll" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.Tooling.dll"
  install -Dm644 "${publish_dir}/HomeHarbor.WebDav.dll" "${pkgdir}/usr/lib/homeharbor/api/HomeHarbor.WebDav.dll"
  install -Dm644 "${publish_dir}/appsettings.json" "${pkgdir}/usr/lib/homeharbor/api/appsettings.json"

  for file in \
    HomeHarbor.Api.pdb \
    HomeHarbor.Core.pdb \
    HomeHarbor.Tooling.pdb \
    HomeHarbor.WebDav.pdb \
    HomeHarbor.Api.staticwebassets.endpoints.json \
    HomeHarbor.Api.staticwebassets.runtime.json \
    web.config; do
    if [[ -f "${publish_dir}/${file}" ]]; then
      install -Dm644 "${publish_dir}/${file}" "${pkgdir}/usr/lib/homeharbor/api/${file}"
    fi
  done

  if [[ -d "${publish_dir}/wwwroot" ]]; then
    cp -a "${publish_dir}/wwwroot" "${pkgdir}/usr/lib/homeharbor/api/"
  fi

  install -dm755 "${pkgdir}/usr/lib/homeharbor/agent"
  install -Dm755 "${agent_publish_dir}/HomeHarbor.Agent" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Agent"
  install -Dm644 "${agent_publish_dir}/HomeHarbor.Agent.dll" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Agent.dll"
  install -Dm644 "${agent_publish_dir}/HomeHarbor.Agent.deps.json" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Agent.deps.json"
  install -Dm644 "${agent_publish_dir}/HomeHarbor.Agent.runtimeconfig.json" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Agent.runtimeconfig.json"
  install -Dm644 "${agent_publish_dir}/HomeHarbor.Tooling.dll" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Tooling.dll"
  if [[ -f "${agent_publish_dir}/HomeHarbor.Agent.pdb" ]]; then
    install -Dm644 "${agent_publish_dir}/HomeHarbor.Agent.pdb" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Agent.pdb"
  fi
  if [[ -f "${agent_publish_dir}/HomeHarbor.Tooling.pdb" ]]; then
    install -Dm644 "${agent_publish_dir}/HomeHarbor.Tooling.pdb" "${pkgdir}/usr/lib/homeharbor/agent/HomeHarbor.Tooling.pdb"
  fi

  _link_published_dotnet_libraries "${publish_dir}" "${pkgdir}/usr/lib/homeharbor/api"
  _link_published_dotnet_libraries "${agent_publish_dir}" "${pkgdir}/usr/lib/homeharbor/agent"

  install -Dm644 "${source_dir}/os/systemd/homeharbor-api.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-api.service"
  install -Dm644 "${source_dir}/os/systemd/valkey.service.d/homeharbor.conf" "${pkgdir}/usr/lib/systemd/system/valkey.service.d/homeharbor.conf"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-postgresql.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-postgresql.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-postgresql-init.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-postgresql-init.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-postgresql-bootstrap.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-postgresql-bootstrap.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-boot-attempt.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-boot-attempt.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-boot-success.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-boot-success.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-firstboot.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-firstboot.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-setup-bootstrap-consume.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-setup-bootstrap-consume.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-setup-bootstrap-consume.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-setup-bootstrap-consume.path"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-storage-apply.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-storage-apply.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-storage-apply.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-storage-apply.path"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-ota-commit.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-ota-commit.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-caddy-render.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-caddy-render.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-caddy-render.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-caddy-render.path"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-tls-trust.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-tls-trust.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-storage-health.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-storage-health.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-storage-health.timer" "${pkgdir}/usr/lib/systemd/system/homeharbor-storage-health.timer"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-smbd.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-smbd.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-nmbd.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-nmbd.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-smb-apply.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-smb-apply.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-smb-apply.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-smb-apply.path"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-container-apply.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-container-apply.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-container-apply.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-container-apply.path"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-system-app-apply.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-system-app-apply.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-system-app-apply.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-system-app-apply.path"
  install -Dm644 "${source_dir}/os/systemd/caddy.service.d/homeharbor-config.conf" "${pkgdir}/usr/lib/systemd/system/caddy.service.d/homeharbor-config.conf"
  sed -i "s/^Environment=HOMEHARBOR_VERSION=.*/Environment=HOMEHARBOR_VERSION=${_homeharbor_version}/" \
    "${pkgdir}/usr/lib/systemd/system/homeharbor-api.service"
  sed -i "s/^Environment=HOMEHARBOR_CHANNEL=.*/Environment=HOMEHARBOR_CHANNEL=${_homeharbor_channel}/" \
    "${pkgdir}/usr/lib/systemd/system/homeharbor-api.service"

  install -Dm755 "${avb_helper}" "${pkgdir}/usr/lib/homeharbor/homeharbor-avb"
  install -Dm755 "${init_helper}" "${pkgdir}/boot/init/homeharbor-verity"

  install -Dm644 "${source_dir}/packaging/arch/homeharbor.sysusers" "${pkgdir}/usr/lib/sysusers.d/homeharbor.conf"
  install -Dm644 "${source_dir}/packaging/arch/homeharbor.tmpfiles" "${pkgdir}/usr/lib/tmpfiles.d/homeharbor.conf"
  install -dm755 "${pkgdir}/etc/homeharbor" "${pkgdir}/homeharbor-data"
}

package_homeharbor-recovery() {
  local source_dir="${srcdir}/${_source_root}"
  local recovery_publish_dir="${srcdir}/${_recovery_publish_root}"
  local avb_helper="${srcdir}/${_avb_helper}"
  pkgdesc='HomeHarbor recovery environment'
  depends=(
    'android-tools'
    'device-mapper'
    'dotnet-runtime'
    'jq'
    'openssl'
    'systemd'
    "dotnet-system-commandline=${pkgver}-${pkgrel}"
    "dotnet-yamldotnet=${pkgver}-${pkgrel}"
  )

  install -dm755 "${pkgdir}/usr/lib/homeharbor/recovery"
  install -Dm755 "${recovery_publish_dir}/HomeHarbor.Recovery" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Recovery"
  install -Dm644 "${recovery_publish_dir}/HomeHarbor.Recovery.dll" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Recovery.dll"
  install -Dm644 "${recovery_publish_dir}/HomeHarbor.Recovery.deps.json" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Recovery.deps.json"
  install -Dm644 "${recovery_publish_dir}/HomeHarbor.Recovery.runtimeconfig.json" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Recovery.runtimeconfig.json"
  install -Dm644 "${recovery_publish_dir}/HomeHarbor.Tooling.dll" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Tooling.dll"

  if [[ -f "${recovery_publish_dir}/HomeHarbor.Recovery.pdb" ]]; then
    install -Dm644 "${recovery_publish_dir}/HomeHarbor.Recovery.pdb" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Recovery.pdb"
  fi
  if [[ -f "${recovery_publish_dir}/HomeHarbor.Tooling.pdb" ]]; then
    install -Dm644 "${recovery_publish_dir}/HomeHarbor.Tooling.pdb" "${pkgdir}/usr/lib/homeharbor/recovery/HomeHarbor.Tooling.pdb"
  fi
  _link_published_dotnet_libraries "${recovery_publish_dir}" "${pkgdir}/usr/lib/homeharbor/recovery"

  install -Dm644 "${source_dir}/os/systemd/homeharbor-fastbootd.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-fastbootd.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-recovery-action.service" "${pkgdir}/usr/lib/systemd/system/homeharbor-recovery-action.service"
  install -Dm644 "${source_dir}/os/systemd/homeharbor-recovery-action.path" "${pkgdir}/usr/lib/systemd/system/homeharbor-recovery-action.path"
  install -Dm644 "${source_dir}/os/systemd/network/20-homeharbor-recovery-wired.network" "${pkgdir}/etc/systemd/network/20-homeharbor-recovery-wired.network"
  install -Dm644 "${source_dir}/os/systemd/serial-getty@ttyS0.service.d/recovery-autologin.conf" "${pkgdir}/etc/systemd/system/serial-getty@ttyS0.service.d/recovery-autologin.conf"
  install -Dm644 "${source_dir}/os/systemd/getty@tty1.service.d/recovery-autologin.conf" "${pkgdir}/etc/systemd/system/getty@tty1.service.d/recovery-autologin.conf"
  install -Dm644 "${source_dir}/packaging/arch/homeharbor-recovery.sysusers" "${pkgdir}/usr/lib/sysusers.d/homeharbor_recovery.conf"
  install -Dm644 "${source_dir}/packaging/arch/homeharbor-recovery.tmpfiles" "${pkgdir}/usr/lib/tmpfiles.d/homeharbor_recovery.conf"
  install -Dm755 "${avb_helper}" "${pkgdir}/usr/lib/homeharbor/homeharbor-avb"
  install -dm755 "${pkgdir}/etc/homeharbor" "${pkgdir}/homeharbor-data"
}

package_homeharbor-installer() {
  local source_dir="${srcdir}/${_source_root}"
  local installer_publish_dir="${srcdir}/${_installer_publish_root}"
  local avb_helper="${srcdir}/${_avb_helper}"
  pkgdesc='HomeHarbor live disk installer'
  depends=(
    'android-tools'
    'btrfs-progs'
    'cryptsetup'
    'device-mapper'
    'dotnet-runtime'
    'dosfstools'
    'erofs-utils'
    'gpm'
    'mdadm'
    'xfsprogs'
    'gptfdisk'
    'jq'
    'mokutil'
    'openssl'
    'systemd'
    'tpm2-tss'
  )

  install -dm755 "${pkgdir}/usr/lib/homeharbor/installer"
  cp -a "${installer_publish_dir}/." "${pkgdir}/usr/lib/homeharbor/installer/"
  chmod 0755 "${pkgdir}/usr/lib/homeharbor/installer/HomeHarbor.Installer"
  find "${pkgdir}/usr/lib/homeharbor/installer" -type f ! -name HomeHarbor.Installer -exec chmod 0644 {} +

  install -Dm755 "${avb_helper}" "${pkgdir}/usr/lib/homeharbor/homeharbor-avb"
  install -Dm644 "${source_dir}/certs/homeharbor-secure-boot.crt" "${pkgdir}/usr/share/homeharbor/secure-boot/homeharbor-secure-boot.crt"
  install -Dm644 "${source_dir}/packaging/arch/homeharbor-recovery.sysusers" "${pkgdir}/usr/lib/sysusers.d/homeharbor-installer.conf"
  install -dm755 "${pkgdir}/etc/homeharbor" "${pkgdir}/opt/homeharbor-installer/payloads"
}

for _dotnet_key in "${_dotnet_keys[@]}"; do
  eval "package_dotnet-${_dotnet_key}() { _package_dotnet_library '${_dotnet_key}'; }"
done
