build() {
  make -C "${pkgname}-${pkgver}"
}

check() {
  make -C "${pkgname}-${pkgver}" test
}

package() {
  make -C "${pkgname}-${pkgver}" DESTDIR="$pkgdir" install
  install -m0755 "${pkgname}-${pkgver}/test/dismod" "$pkgdir/usr/bin/sedismod"
  install -m0755 "${pkgname}-${pkgver}/test/dispol" "$pkgdir/usr/bin/sedispol"
}
