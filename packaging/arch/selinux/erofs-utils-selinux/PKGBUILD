# Maintainer: David Runge <dvzrv@archlinux.org>
#
# HomeHarbor provenance:
# - Arch Linux packaging baseline: archlinux/packaging/packages/erofs-utils
#   commit 2d7fdc1959436963acc85da321eca4f568f4a3c0 (2026-07-02).
# - No archlinuxhardened erofs-utils-selinux recipe existed at the referenced
#   SELinux packaging revision; this delta enables erofs-utils' upstream
#   --with-selinux build option directly.
# - This recipe builds from source; no archlinuxhardened binary package is used.

pkgbase=erofs-utils-selinux
pkgname=(erofs-utils-selinux erofsfuse-selinux)
pkgver=1.9.2
pkgrel=1
pkgdesc="Userspace utilities for linux-erofs file system with SELinux support"
arch=(x86_64)
url="https://git.kernel.org/pub/scm/linux/kernel/git/xiang/erofs-utils.git"
license=(
  Apache-2.0
  GPL-2.0-or-later
)
groups=(selinux)
makedepends=(
  curl
  fuse2
  glibc
  libdeflate
  libselinux
  lz4
  openssl
  util-linux-selinux
  xxhash
  xz
  zlib
  zstd
)
source=($url/snapshot/${pkgbase/-selinux}-$pkgver.tar.gz)
sha512sums=('53e30341013ec50f30ea39630482bd3f2e80304f3cb4db16bccf90432c2c9ac9e5bd59d01fc5d34042e62270cb15aadf7c2637fab2959ee27844290d9f33b5b9')
b2sums=('ce4caa3ea622f1122c076b71265570bc0b43aae4388efaa2c1b0f3b678e00b0b50e7de81c3339458a8722ac938ed37ebe5d2f258dc5ca92e81668279cc5cdaf5')

prepare() {
  cd ${pkgbase/-selinux}-$pkgver
  autoreconf -fiv
}

build() {
  local configure_options=(
    --enable-fuse
    --enable-lzma
    --enable-multithreading
    --prefix=/usr
    --sbindir=/usr/bin/
    --with-libdeflate
    --with-selinux
  )

  cd ${pkgbase/-selinux}-$pkgver
  MAX_BLOCK_SIZE=65536 ./configure "${configure_options[@]}"
  # prevent excessive overlinking due to libtool
  sed -i -e 's/ -shared / -Wl,-O1,--as-needed\0/g' libtool
  make
}

check() {
  make -k check -C ${pkgbase/-selinux}-$pkgver
}

_pick() {
  local p="$1" f d; shift
  for f; do
    d="$srcdir/$p/${f#$pkgdir/}"
    mkdir -vp "$(dirname "$d")"
    mv -v "$f" "$d"
    rmdir -vp --ignore-fail-on-non-empty "$(dirname "$f")"
  done
}

package_erofs-utils-selinux() {
  depends+=(
    curl libcurl.so
    glibc
    libdeflate libdeflate.so
    libselinux libselinux.so
    lz4 liblz4.so
    openssl libcrypto.so
    util-linux-libs-selinux libuuid.so
    xxhash libxxhash.so
    xz liblzma.so
    zstd libzstd.so
    zlib libz.so
  )
  optdepends=(
    'erofsfuse-selinux: for FUSE file system client'
  )
  provides=("erofs-utils=${pkgver}-${pkgrel}")
  conflicts=(erofs-utils)

  make DESTDIR="$pkgdir/" install -C ${pkgbase/-selinux}-$pkgver
  install -vDm 644 ${pkgbase/-selinux}-$pkgver/{AUTHORS,ChangeLog,README} -t "$pkgdir/usr/share/doc/$pkgname/"

  cd "$pkgdir"
  _pick erofsfuse usr/bin/erofsfuse
  _pick erofsfuse usr/share/man/man1/erofsfuse*
}

package_erofsfuse-selinux() {
  pkgdesc="FUSE file system client for erofs file system with SELinux support"
  depends+=(
    fuse2
    glibc
    libdeflate libdeflate.so
    lz4 liblz4.so
    libselinux libselinux.so
    xxhash libxxhash.so
    xz liblzma.so
    zstd libzstd.so
  )
  provides=("erofsfuse=${pkgver}-${pkgrel}")
  conflicts=(erofsfuse)

  mv -v erofsfuse/* "$pkgdir"
  install -vDm 644 ${pkgbase/-selinux}-$pkgver/{AUTHORS,ChangeLog,README} -t "$pkgdir/usr/share/doc/$pkgname/"
}
