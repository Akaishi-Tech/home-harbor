[Unit]
Description=HomeHarbor NetBIOS name service
Requires=homeharbor-selinux-ready.target
After=homeharbor-selinux-ready.target network-online.target homeharbor-smbd.service
Wants=network-online.target

[Service]
Type=simple
ExecStartPre=/usr/lib/homeharbor/agent/HomeHarbor.Agent ensure-smb-config
ExecStart=/usr/bin/nmbd --foreground --no-process-group --configfile=/var/lib/homeharbor/samba/smb.conf
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
