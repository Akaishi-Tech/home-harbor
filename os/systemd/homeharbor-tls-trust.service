[Unit]
Description=Display HomeHarbor TLS CA trust fingerprint
Requires=homeharbor-selinux-ready.target caddy.service
After=homeharbor-selinux-ready.target caddy.service
StartLimitIntervalSec=120
StartLimitBurst=12

[Service]
Type=oneshot
ExecStart=/usr/lib/homeharbor/agent/HomeHarbor.Agent display-tls-trust
RemainAfterExit=yes
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
