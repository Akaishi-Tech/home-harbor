{
  "HomeHarbor": {
    "Storage": {
      "DataRoot": "./data"
    },
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=homeharbor_dev;Username=homeharbor;Pooling=true"
    },
    "Cache": {
      "UnixSocketPath": "./data/run/valkey/homeharbor.sock",
      "InstanceName": "homeharbor-dev:",
      "OverviewTtlSeconds": 30
    },
    "Jwt": {
      "SigningKeyPath": "./data/jwt-signing.key"
    },
    "Automation": {
      "TokenPath": "./data/automation.jwt"
    },
    "Runtime": {
      "RequestDirectory": "./data/run",
      "SmbCredentialDirectory": "./data/run/smb-credentials"
    },
    "Frontend": {
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
