{
  "HomeHarbor": {
    "Api": {
      "PublicOrigin": "https://homeharbor.local"
    },
    "Storage": {
      "DataRoot": "/homeharbor-data",
      "MaxUploadBytes": 21474836480
    },
    "Database": {
      "ConnectionString": "Host=/run/postgresql;Port=5432;Database=homeharbor;Username=homeharbor;Pooling=true"
    },
    "Cache": {
      "UnixSocketPath": "/run/valkey/homeharbor.sock",
      "InstanceName": "homeharbor:",
      "OverviewTtlSeconds": 30
    },
    "Jwt": {
      "Issuer": "HomeHarbor",
      "Audience": "HomeHarbor.Frontend",
      "SigningKeyPath": "/var/lib/homeharbor/api/jwt-signing.key",
      "AccessTokenDays": 30
    },
    "Automation": {
      "TokenPath": "/run/homeharbor/automation.jwt"
    },
    "Setup": {
      "BootstrapCodePath": "/var/lib/homeharbor/setup/bootstrap-code",
      "BootstrapCompletePath": "/var/lib/homeharbor/setup/bootstrap-complete",
      "ConsumeRequestPath": "/run/homeharbor/setup-bootstrap-consume"
    },
    "Runtime": {
      "RequestDirectory": "/run/homeharbor",
      "SmbCredentialDirectory": "/run/homeharbor-smb-credentials"
    },
    "Frontend": {
      "AllowedOrigins": []
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
